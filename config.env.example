# AI Film Studio -- API Credentials
# Copy this file to `config.env` and fill in your keys.
# Source it before running any script: `source config.env`
# KEEP `config.env` PRIVATE. It's gitignored.

# Google Gemini API (Nano Banana images + Veo video)
# https://aistudio.google.com/apikey
export GEMINI_API_KEY=""

# BytePlus Ark (Seedance 2.0 direct API)
# https://console.byteplus.com/ark
export ARK_API_KEY=""

# LTX Video (Lightricks, direct API)
# https://docs.ltx.video/authentication
export LTXV_API_KEY=""

# ElevenLabs (voice, music, SFX)
# https://elevenlabs.io  (Voice IDs: https://elevenlabs.io/app/voice-library)
export ELEVENLABS_KEY=""
export ELEVENLABS_VOICE=""

# Cloudflare R2 (optional -- only needed if you want Seedance to consume
# local image files; the script auto-uploads them to R2 to get a public URL).
# https://developers.cloudflare.com/r2/
export R2_ACCOUNT=""
export R2_ACCESS_KEY=""
export R2_SECRET_KEY=""
export R2_BUCKET=""
export R2_PUBLIC_URL=""
